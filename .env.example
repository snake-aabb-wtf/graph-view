# =====================================================
# Graph View 2 · LLM 转换器配置示例
# =====================================================
# 复制为 .env 后按需修改。所有 VITE_* 变量都会被 vite
# 静态替换到客户端 bundle 里 —— **不要** 把 API key 放这里。
# =====================================================

# 默认 LLM endpoint(同源代理会转发到这里)。
# 仅 OpenAI 协议(/v1/chat/completions)。
# 推荐:
#   OpenAI 官方     https://api.openai.com
#   DeepSeek        https://api.deepseek.com
#   Moonshot/Kimi   https://api.moonshot.cn
#   OpenRouter      https://openrouter.ai/api
#   Ollama(本地)    http://localhost:11434/api
#   LM Studio(本地) http://localhost:1234/v1
# 不填则默认转发到 OpenAI 官方。
VITE_LLM_DEFAULT_TARGET=https://api.openai.com

# 默认 baseUrl 路径。同源 '/llm' 走 vite 代理(推荐,key 不进 bundle);
# 也可以填直连 endpoint 如 https://api.deepseek.com/v1
# VITE_LLM_BASE_URL=/llm

# 默认 model 名(用户可在 UI 改)
# VITE_LLM_MODEL=gpt-4o-mini
# VITE_LLM_MODEL=deepseek-chat
# VITE_LLM_MODEL=moonshot-v1-8k
# VITE_LLM_MODEL=llama3

# =====================================================
# API Key 怎么填?
# =====================================================
# **永远不要** 写在 .env / .env.local / 任何 git 跟踪的文件里。
# 在应用顶栏"AI 生成"按钮弹出的对话框里直接填。
# 关闭浏览器标签页即清空(不持久化到 localStorage)。
#
# 走同源 '/llm' 代理时,vite 会把你的 key 通过 X-LLM-Authorization 头
# 转给真实的 Authorization:Bearer ... 转发给上游;key 不会出现在前端 bundle。
#
# 直连外部 endpoint 时,key 在浏览器 Network 面板可见 —— 务必确认对方
# 允许 CORS,且只在受信任环境使用。
